# ── .env.local.example ───────────────────────────────────────────────────────
# Use this ONLY when you run the bot process on your host machine
# (e.g. `poetry run python -m telegram_llm_bot.main`) while the infra
# containers run inside docker compose.
#
# Copy to .env.local and merge with .env.bot, OR export these vars in your
# shell before launching the bot. The Docker service names in .env/.env.bot
# (mongo, weaviate, minio) only resolve inside the compose network, so they
# must be overridden to localhost when running on the host.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB — published on 27017 by compose.yaml
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=matchbot

# Weaviate — published on 8080 (HTTP) and 50051 (gRPC) by compose.yaml
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080

# MinIO — published on 9000 (API) and 9001 (console) by compose.yaml
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes
MINIO_SECURE=false
